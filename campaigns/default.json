{
  "campaigns": [
    {
      "id": "federation-stewardship",
      "title": "Federation Stewardship",
      "north_star": "execute tasks with minimal tokens by making the architecture itself intelligent",
      "heartbeat_interval": 4,
      "max_active_missions": 2,
      "success_signals": [
        {
          "kind": "federation_healthy",
          "target": true,
          "description": "all discovered peers should be ALIVE or healing"
        },
        {
          "kind": "immune_clean",
          "target": true,
          "description": "self-diagnostics should find 0 test failures"
        },
        {
          "kind": "ci_green",
          "target": true,
          "description": "CI should pass on all federation repos"
        },
        {
          "kind": "active_missions_at_most",
          "target": 3,
          "description": "bounded execution — no thrashing"
        }
      ],
      "missions": [
        {
          "id": "mission_steward_autonomy",
          "name": "Steward Autonomy",
          "description": "Autonomous codebase maintenance every 15 minutes",
          "priority": "HIGH",
          "status": "ACTIVE",
          "owner": "steward",
          "strategies": [
            {
              "id": "strategy_quick_check",
              "name": "Quick Health Check",
              "description": "Run senses, check CI status, scan for issues",
              "frequency": "DAILY",
              "intent_type": "health_check",
              "intent_template": {
                "actions": [
                  "sense_scan",
                  "ci_check"
                ]
              },
              "requires_ci_green": false,
              "requires_no_pending_intents": true,
              "max_executions_per_day": 6,
              "enabled": true,
              "trigger": {
                "trigger_type": "IDLE_BASED",
                "idle_minutes": 10
              }
            },
            {
              "id": "strategy_update_deps",
