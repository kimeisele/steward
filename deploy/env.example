# Steward Daemon — Environment Configuration
# Copy to /opt/steward/.env and fill in your values.

# ── LLM Providers (at least one required) ──────────────────────────
# Google Gemini (FREE tier)
GOOGLE_API_KEY=

# Mistral (FREE tier)
MISTRAL_API_KEY=

# Groq (FREE tier — llama-3.3-70b)
GROQ_API_KEY=

# ── Federation ─────────────────────────────────────────────────────
# Path to federation nadi directory (git checkout of wiki repo).
# Must be a git clone of the shared federation repo.
# Example: /opt/steward/federation (cloned from github.com/org/repo.wiki.git)
STEWARD_FEDERATION_DIR=

# ── Agent-Internet Integration ─────────────────────────────────────
# Base URL and token for agent-internet Lotus API.
# Only needed if consuming semantic surfaces.
STEWARD_AGENT_INTERNET_BASE_URL=
STEWARD_AGENT_INTERNET_TOKEN=
STEWARD_AGENT_INTERNET_TIMEOUT_S=5

# ── Optional: Telegram Bot ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=

# ── Optional: API Server ──────────────────────────────────────────
STEWARD_API_TOKEN=
STEWARD_API_HOST=0.0.0.0
STEWARD_API_PORT=8420

# ── Optional: Web Search ──────────────────────────────────────────
TAVILY_API_KEY=
